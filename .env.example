# Client-side (VITE_ prefix = bundled into browser JS — keep secrets OUT)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Image generation engine selection: "gemini" (default) or "nano-banana"
# VITE_IMAGE_ENGINE=nano-banana
# VITE_REPLICATE_API_KEY=r8_...     # Required when VITE_IMAGE_ENGINE=nano-banana

# Server-side API keys — set in Vercel Environment Variables, NOT here
# GEMINI_API_KEY=your-gemini-key
# REPLICATE_API_KEY=your-replicate-key
# FAL_KEY=your-fal-key
# RUNWAY_API_KEY=key_...              # Seedance 2.0 via Runway (cinematic I2V)

# Video I2V models
# VITE_REPLICATE_API_TOKEN=r8_...     # Kling v2.1 via Replicate (volume, $)
# VITE_RUNWAY_API_KEY=key_...         # Seedance 2.0 via Runway (cinematic, $$)
#                                       Phase 2: move to server-side proxy

# For Brands form (optional — falls back gracefully if not set)
# VITE_LUMINA_INQUIRY_EMAIL=brand@lumina-models.com              # Inquiry 受信先(FormSubmit.co 経由で通知)
# VITE_LUMINA_GMEET_URL=https://calendar.app.google/...          # Google Calendar 予約ページURL

# Talent Production Pipeline (parent repo: fukugyo-content-studio)
# ANTHROPIC_API_KEY=sk-ant-...
# HEYGEN_API_KEY=sk_V2_...           # Avatar lip-sync video for IG Reels
# ELEVENLABS_API_KEY=sk_...          # Voice clone per talent
# PEXELS_API_KEY=...                 # B-roll video curation
# YOUTUBE_API_KEY=AIza...            # Viral research
# KLING_ACCESS_KEY=...               # Image-to-video (direct JWT)
# KLING_SECRET_KEY=...
